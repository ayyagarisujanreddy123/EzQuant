# Copy this to .env and fill in values as needed.
# Every var has a sensible default in app/core/config.py,
# so you can run the server with NO .env file at all during early hackathon work.

# --- Server ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- CORS ---
# Comma-separated list. Next.js dev server is on :3000 by default.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Caching ---
# Seconds. Intraday bars change frequently; daily bars rarely.
MARKET_CACHE_TTL_INTRADAY=60
MARKET_CACHE_TTL_DAILY=86400
