# Copy this to .env and fill in values as needed.
# Every var has a sensible default, so you can run with NO .env file.

# --- Server ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Caching ---
MARKET_CACHE_TTL_INTRADAY=60
MARKET_CACHE_TTL_DAILY=86400

# --- yfinance retries ---
# Yahoo sometimes returns HTML block pages instead of JSON — a short retry clears it.
YFINANCE_MAX_RETRIES=2
YFINANCE_RETRY_BACKOFF_SECONDS=1.5
