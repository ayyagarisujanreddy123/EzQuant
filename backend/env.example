# Copy this to .env (repo root) and fill in values as needed.

# --- Server ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Market data caching (in-memory) ---
MARKET_CACHE_TTL_INTRADAY=60
MARKET_CACHE_TTL_DAILY=86400

# --- yfinance retries ---
# Yahoo sometimes returns HTML block pages instead of JSON — a short retry clears it.
YFINANCE_MAX_RETRIES=2
YFINANCE_RETRY_BACKOFF_SECONDS=1.5

# --- OHLCV persistent cache (Supabase ohlcv_cache) adaptive TTL ---
OHLCV_CACHE_RECENT_WINDOW_DAYS=7
OHLCV_CACHE_TTL_RECENT_HOURS=1
OHLCV_CACHE_TTL_HISTORICAL_DAYS=30

# --- Supabase (backend-side; pipeline_runs + ohlcv_cache writes, JWT verify) ---
# SUPABASE_URL mirrors NEXT_PUBLIC_SUPABASE_URL from .env.local
# SUPABASE_JWT_SECRET — Supabase Dashboard → Project Settings → API → JWT Settings
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
