# ─────────────────────────────────────────────────────────────────────────────
# EzQuant · Environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real secrets.
#
# Only NEXT_PUBLIC_* vars are exposed to the browser. Everything else is
# server-only (Next.js API routes / server actions).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Google Gemini · Copilot chat, RAG, multimodal PDF ingest ────────────────
# Consumer:  lib/api/placeholders.ts → streamCopilotChat (POST /api/agent/chat)
# Get key:   https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ─── Supabase · Project persistence + (optional) auth ────────────────────────
# Consumer:  lib/api/placeholders.ts → fetchProjects, fetchProject, saveProject
# Tables:    projects, pipeline_runs, knowledge_chunks (pgvector)
# Dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Market Data · Ticker Source block, backtest runs ────────────────────────
# Consumer: get_live_market_data tool · Ticker Source block · runPipeline
# Pick ONE provider. Polygon.io recommended for quality + free tier.
# Docs:
#   Polygon:       https://polygon.io/docs
#   Alpha Vantage: https://www.alphavantage.co/documentation/
#   Tiingo:        https://www.tiingo.com/documentation
#   Finnhub:       https://finnhub.io/docs/api
POLYGON_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# TIINGO_API_KEY=
# FINNHUB_API_KEY=

# ─── Vector Store · RAG / search_knowledge tool ──────────────────────────────
# Default: pgvector inside the Supabase project above (no extra keys).
# Or swap to a managed vector DB:
# PINECONE_API_KEY=
# PINECONE_INDEX=ezquant-knowledge
# WEAVIATE_URL=
# WEAVIATE_API_KEY=

# ─── Embeddings · Used if NOT using Gemini embeddings ────────────────────────
# If GEMINI_EMBEDDING_MODEL is set above, OpenAI is not required.
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Pipeline Runner · Executes the block graph ──────────────────────────────
# Consumer: lib/api/placeholders.ts → runPipeline (POST /api/pipeline/run)
# Your own Python/Node service that runs pandas + backtesting on the graph.
PIPELINE_RUNNER_URL=http://localhost:8000
PIPELINE_RUNNER_TOKEN=

# ─── Object Storage · Copilot PDF / CSV attachments ──────────────────────────
# Consumer: ingest_document tool (Copilot attaches → uploaded → chunked + embedded)
# Any S3-compatible bucket works (AWS S3, Cloudflare R2, Supabase Storage).
S3_ENDPOINT=
S3_BUCKET=ezquant-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ─── Observability · Optional ────────────────────────────────────────────────
# SENTRY_DSN=
# LOGFLARE_API_KEY=
LOG_LEVEL=info
